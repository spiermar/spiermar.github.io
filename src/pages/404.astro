---
/**
 * 404 Not Found Page
 * 
 * Custom error page displayed when a requested page doesn't exist.
 * Features a minimal, centered layout with an icon, message, and
 * navigation back to the homepage.
 * 
 * Design:
 * - No header, navigation, or footer for focused experience
 * - Centered content with SVG icon
 * - Clear messaging about the error
 * - Single CTA button to return home
 * 
 * Route: /404 (automatically served for non-existent pages)
 * 
 * @page
 */

import { siteConfig } from '../config';
import '../styles/global.css';

const pageTitle = '404 - Page Not Found';
---

<!DOCTYPE html>
<html lang={siteConfig.language} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex, nofollow" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    
    <!-- Theme initialization script (matches BaseLayout behavior) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        const theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    
    <!-- Layout-specific styles using global design tokens -->
    <style>
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-xl) var(--space-lg);
      }

      .container {
        max-width: 500px;
        width: 100%;
        text-align: center;
      }

      .icon {
        width: 80px;
        height: 80px;
        margin: 0 auto var(--space-xl);
        color: var(--color-text-muted);
        opacity: 0.6;
      }

      .error-code {
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-semibold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-muted);
        margin-bottom: var(--space-md);
      }

      h1 {
        font-size: var(--font-size-4xl);
        font-weight: var(--font-weight-bold);
        letter-spacing: -0.02em;
        margin-bottom: var(--space-md);
        color: var(--color-text);
      }

      .description {
        font-size: var(--font-size-lg);
        line-height: var(--line-height-relaxed);
        color: var(--color-text-secondary);
        margin-bottom: var(--space-2xl);
      }

      .home-button {
        display: inline-block;
        padding: 0.875rem 2rem;
        background: var(--color-text);
        color: var(--color-bg);
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-base);
        text-decoration: none;
        border-radius: var(--border-radius-md);
        transition: opacity var(--transition-base);
      }

      .home-button:hover {
        opacity: 0.85;
      }

      @media (max-width: 640px) {
        .icon {
          width: 64px;
          height: 64px;
          margin-bottom: var(--space-lg);
        }

        .error-code {
          font-size: var(--font-size-sm);
        }

        h1 {
          font-size: var(--font-size-2xl);
        }

        .description {
          font-size: var(--font-size-base);
          margin-bottom: var(--space-xl);
        }

        .home-button {
          padding: var(--space-sm) 1.75rem;
          font-size: var(--font-size-sm);
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- 404 Icon -->
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>

      <div class="error-code">404 Error</div>
      
      <h1>Page Not Found</h1>
      
      <p class="description">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>

      <a href="/" class="home-button">Back to Home</a>
    </div>
  </body>
</html>
